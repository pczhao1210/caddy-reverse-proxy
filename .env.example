# AI Docker Farm Gateway local/deployment environment
# Copy this sample to .env, then edit .env for local runs and VM deployments.
# See docs/operations.md for all options and meanings.

GATEWAY_PROFILE=vm
GATEWAY_ADMIN_TOKEN=change-me
GATEWAY_ADMIN_TOKENS=
GATEWAY_AUTH_REQUIRED=true
GATEWAY_PROTECTED_ALLOW_BEARER=true
GATEWAY_PROTECTED_ALLOW_ADMIN_HEADER=true
GATEWAY_PROTECTED_HEADER_NAME=
GATEWAY_PROTECTED_HEADER_VALUE=

GATEWAY_CONFIG_FILE=/config/platform.example.json
GATEWAY_ROUTES_FILE=/data/platform/routes.json
GATEWAY_RECONCILE_SECONDS=30

GATEWAY_CONTROL_LISTEN=:8080
GATEWAY_MANAGEMENT_HOST=
GATEWAY_HTTP_LISTEN=:80
GATEWAY_HTTPS_LISTEN=:443
GATEWAY_CADDY_ADMIN_ENDPOINT=http://127.0.0.1:2019
GATEWAY_STATE_DIR=/data/platform
GATEWAY_CADDY_DATA_DIR=/data/caddy
GATEWAY_CERTIFICATE_ISSUER=default
GATEWAY_CERTIFICATE_EMAIL=
GATEWAY_CERTIFICATE_STAGING=false
GATEWAY_CERTIFICATE_CA_DIRECTORY=

GATEWAY_HEALTH_ENABLED=true
GATEWAY_HEALTH_TIMEOUT_SECONDS=3
GATEWAY_HEALTH_DEFAULT_PATH=/

GATEWAY_AUDIT_ENABLED=true
GATEWAY_AUDIT_FILE=/data/platform/audit.jsonl

GATEWAY_DOCKER_ENABLED=true
GATEWAY_DOCKER_SOCKET=/var/run/docker.sock
GATEWAY_DOCKER_ENDPOINT=

GATEWAY_AZURE_ENABLED=false
GATEWAY_AZURE_MANAGE_DNS=true
GATEWAY_AZURE_MANAGE_NSG=true
GATEWAY_AZURE_SUBSCRIPTION_ID=
GATEWAY_AZURE_RESOURCE_GROUP=
GATEWAY_AZURE_DNS_ZONE=
GATEWAY_AZURE_NSG_NAME=
GATEWAY_AZURE_NSG_PRIORITY=120
GATEWAY_AZURE_NSG_SOURCE_PREFIXES=*
GATEWAY_PUBLIC_IP_ADDRESS=
