{
  "routes": [
    {
      "id": "sample-httpbin",
      "host": "httpbin.localhost",
      "exposure": "public",
      "enabled": true,
      "public": true,
      "https": false,
      "websocket": false,
      "source": "explicit",
      "security": {
        "maxRequestBodyBytes": 2097152,
        "additionalDeniedMethods": ["M-SEARCH"],
        "additionalDeniedPathPrefixes": ["/private"],
        "blockedCidrs": ["192.0.2.0/24"]
      },
      "upstreams": [
        {
          "name": "httpbin",
          "url": "http://httpbin:8080"
        }
      ]
    }
  ]
}
